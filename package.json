{
	"name": "acsd-assistant",
	"version": "3.1.1",
	"description": "A bot for enhancing your ACSD experience.",
	"main": "src/index.ts",
	"module": "src/index.ts",
	"type": "module",
	"scripts": {
		"manifest": "bun run src/manifestGen.ts",
		"processStart": "bun manifest && pm2 start . --interpreter bun --name \"ACSD Assistant\"",
		"processRestart": "bun stop && bun processStart",
		"start": "bun processStart && pm2 logs",
		"deploy-start": "bun processStart -- -- --deploy && pm2 logs",
		"restart": "bun processRestart && pm2 logs",
		"deploy-restart": "bun processRestart -- -- -- --deploy && pm2 logs",
		"stop": "pm2 delete \"ACSD Assistant\"",
		"ci:test": "bun manifest && bun run . --nologin",
		"build:bundle": "bun manifest && bun build ./src/index.ts --outfile=./dist/bundle.js --target=bun --external=pg --external=better-sqlite3 --external=pg-query-stream --external=tedious --external=oracledb --external=sqlite3 --external=pgnative --external=redshift --external=mysql --external=zlib-sync",
		"build:obfuscate": "bunx javascript-obfuscator ./dist/bundle.js --output ./dist/obfuscated.js --compact true --self-defending true",
		"build:compile-win-x64": "bun build ./dist/obfuscated.js --compile --target=bun-windows-x64 --outfile=./dist/acsd-assistant-win/acsd-assistant-win.exe --external=zlib-sync",
		"build:compile-linux-x64": "bun build ./dist/obfuscated.js --compile --target=bun-linux-x64 --outfile=./dist/acsd-assistant-linux/acsd-assistant-linux --external=zlib-sync",
		"release:win-x64": "bun build:bundle && bun build:obfuscate && bun build:compile-win-x64",
		"release:linux-x64": "bun build:bundle && bun build:obfuscate && bun build:compile-linux-x64"
	},
	"author": "stolarchukboris",
	"license": "MIT",
	"dependencies": {
		"discord.js": "^14.26.4",
		"knex": "^3.2.10",
		"ms": "^2.1.3",
		"mysql2": "^3.22.5",
		"rozod": "^6.7.1"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"@types/ms": "^2.1.0"
	}
}
